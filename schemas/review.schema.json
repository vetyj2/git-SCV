{ "$schema": "https://json-schema.org/draft/2020-12/schema", "title": "Git-SCV review", "type": "object", "required": ["schema_version", "run_id", "verdict", "safe_claim_made", "may_user_run_install", "may_agent_run_without_user", "reason_codes"], "properties": { "verdict": { "enum": ["blocked-pending-review", "approval-required", "review-required", "no-blocker-observed", "insufficient-coverage", "stale-source", "failed"] }, "safe_claim_made": { "const": false }, "may_user_run_install": { "const": false }, "may_agent_run_without_user": { "const": false }, "reason_codes": { "type": "array", "items": { "type": "string" } } } }
