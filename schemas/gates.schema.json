{ "$schema": "https://json-schema.org/draft/2020-12/schema", "title": "Git-SCV gates", "type": "object", "required": ["schema_version", "run_id", "decision_binding", "sensitive_raw_review", "execution_model_input_review", "execution_command_review"], "properties": { "schema_version": { "type": "string" }, "run_id": { "type": "string" }, "decision_binding": { "type": "object", "required": ["requires_source_fingerprint_hash", "requires_artifact_manifest_sha256", "requires_exact_command_envelope_for_execution"] }, "execution_command_review": { "type": "object", "properties": { "requires_exact_command": { "const": true } } } } }
