{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Git-SCV reachability scenarios",
  "type": "object",
  "required": [
    "artifact_kind",
    "schema_version",
    "contract_version",
    "scenarios"
  ],
  "properties": {
    "artifact_kind": { "const": "reachability_scenarios" },
    "schema_version": { "const": "2" },
    "contract_version": { "const": "artifact-contract-v2" },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scenario_id",
          "user_action",
          "reachable_nodes",
          "blocked_by",
          "safe_to_execute_without_user"
        ],
        "properties": {
          "scenario_id": { "type": "string" },
          "user_action": { "type": "string" },
          "reachable_nodes": { "type": "array", "items": { "type": "string" } },
          "blocked_by": { "type": "array", "items": { "type": "string" } },
          "safe_to_execute_without_user": { "const": false }
        }
      }
    }
  }
}
